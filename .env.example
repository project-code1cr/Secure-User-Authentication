NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/secure_auth_db
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m
CLIENT_URL=http://localhost:3000
APP_NAME=Secure User Authentication System
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Secure Auth <no-reply@example.com>"